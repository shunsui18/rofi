@import "~/.config/rofi/colors.rasi"
@import "~/.config/rofi/special-case/window-background.rasi"

* {
    win-bg:                    @window-background;
    
    mb-bg:                     @base;
    mb-border:                 @blush;

    inbar-bg:                  @rim;
    inbar-border:              @petal;
    inbar-tb-txt:              @seafoam;
    inbar-entry-txt:           @text;
    inbar-entry-ph:            @muted;

    lv-bg:                     @sky;

    el-txt:                    @text;
    el-selected-bg:            @select;
    el-selected-txt:           @text;
    el-selected-border:        @base;
    el-txt-border:             @select;
}